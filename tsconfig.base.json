{
    "compilerOptions": {
        "declaration": false,
        "importHelpers": true,
        "lib": ["es2020", "dom"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noUncheckedSideEffectImports": false,
        "paths": {
            "@fdk-frontend/data-access": ["./libs/data-access/src/index.ts"],
            "@fdk-frontend/data-access/server": ["./libs/data-access/src/server.ts"],
            "@fdk-frontend/localization": ["./libs/localization/src/index.ts"],
            "@fdk-frontend/libs/*": ["./libs/*"],
            "@fdk-frontend/types": ["./libs/types/src/index.ts"],
            "@fdk-frontend/types/server": ["./libs/types/src/server.ts"],
            "@fdk-frontend/ui": ["./libs/ui/src/index.ts"],
            "@fdk-frontend/ui/*": ["./libs/ui/src/lib/*"],
            "@fdk-frontend/utils": ["./libs/utils/src/index.ts"],
            "@fdk-frontend/utils/*": ["./libs/utils/src/lib/*"],
            "@fdk-frontend/utils/server": ["./libs/utils/src/server.ts"],
            "react": ["./node_modules/@types/react"]
        },
        "rootDir": ".",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "es2015",
        "types": ["node"],
        "jsx": "react"
    },
    "exclude": ["node_modules", "tmp", "**/*.stories.tsx"]
}
